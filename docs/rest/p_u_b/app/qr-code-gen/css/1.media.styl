@media (max-width 780px)
    .main
        .editor
            flex-direction column
            justify-content center

            & > :first-child
                align-content center
                justify-content center
                padding 4% 2% 0 0
                width 100%

            #qrcode-img
                align-items center
                flex-direction column
                padding 7% 0 0 0
                width 100%

                b
                    display block

                img
                    align-items center
                    flex-direction column
                    width auto

            & > :last-child
                align-content center
                justify-content center
                padding 2% 0 0 2%
                width 100%

        .sets
            padding 4.5% 1% 0.5% 1%